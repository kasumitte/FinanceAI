# ===========================================================
# Environment Variables
# ===========================================================
# Copy this template to your .env file and insert your values
# Edit with config.py

# --- Postgres user, password, database name ---
# You'll need these 3 parameters if you run it locally  
POSTGRES_PASSWORD=your-password
POSTGRES_USER=your-user-name
POSTGRES_DB=your-db-name

# --- Postgres url ---
DATABASE_URL=postgresql://{POSTGRES_USER}:{POSTGRES_PASSWORD}@{server-IP}:{port}/{POSTGRES_DB}  

# --- LLM API KEY ---
LLM_API_KEY=your-api-key
